{
  "hooks": {
    "SessionStart": [{"hooks": [{"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.py\" SessionStart"}]}],
    "PreToolUse": [{"matcher": "Bash|mcp__.*__boswell_commit", "hooks": [{"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.py\" PreToolUse", "timeout": 10}]}],
    "PostToolUse": [{"matcher": "Read|Edit|Write|Bash|mcp__.*__(boswell_search|boswell_recall|boswell_semantic_search|fetch)", "hooks": [{"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.py\" PostToolUse"}]}],
    "Stop": [{"hooks": [{"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.py\" Stop", "timeout": 10}]}],
    "SessionEnd": [{"hooks": [{"type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.py\" SessionEnd"}]}]
  }
}
